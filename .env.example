# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY
# ═══════════════════════════════════════════════════════════════════════════════
# PSEI Authority Backend Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=PSEI Authority
APP_VERSION=3.0.0
APP_ENV=development
PORT=8080
HOST=0.0.0.0

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/psei
DB_USER=psei_user
DB_PASSWORD=change-me-in-production

# ── JWT Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-prod
JWT_ISSUER=psei-authority
JWT_AUDIENCE=psei-clients
JWT_EXPIRY_MS=86400000

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ── File Storage ───────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_PATH=./uploads
# S3_BUCKET_NAME=
# S3_REGION=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,jpg,png,docx,xlsx

# ── Caching (Redis) ────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password

# ── Background Jobs ────────────────────────────────────────────────────────────
JOBS_ENABLED=true
JOBS_WORKER_COUNT=4

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Monitoring ─────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://your-dsn@sentry.io/project
# GRAFANA_ENDPOINT=https://grafana.your-domain.com

# ── Email / Notifications ──────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ── External Services ──────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# WHATSAPP_API_KEY=
